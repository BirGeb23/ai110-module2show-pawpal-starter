classDiagram
    class Owner {
        +str name
        +int available_minutes
        +list~Pet~ pets
        +add_pet(pet Pet) None
        +get_pet(name str) Optional~Pet~
        +get_all_tasks() list~Task~
        +get_pending_tasks() list~Task~
    }

    class Pet {
        +str name
        +str species
        +dict preferences
        +list~Task~ tasks
        +str pet_id
        +add_task(task Task) None
        +remove_task(task_id str) None
        +get_all_tasks() list~Task~
        +get_pending_tasks() list~Task~
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +Optional~time~ preferred_time
        +str category
        +str frequency
        +bool completed
        +str task_id
        +Optional~date~ due_date
        +bool rolled_over
        +str pet_name
        +mark_complete() None
        +priority_rank() int
        +time_key() time
        +__str__() str
    }

    class Scheduler {
        +Owner owner
        +time start_time
        +int time_budget
        +sort_by_priority(tasks) list~Task~
        +sort_by_time(tasks) list~Task~
        +filter_to_budget(tasks) list~Task~
        +filter_by_pet(tasks, pet_name) list~Task~
        +filter_by_completion(tasks, completed) list~Task~
        +build_plan() list~Task~
        +explain_plan(plan) str
        +create_next_occurrence(task) Optional~Task~
        +advance_recurring_tasks() list~Task~
        +detect_conflicts(tasks) list~str~
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : uses
    Scheduler ..> Task : orders &amp; rolls forward
